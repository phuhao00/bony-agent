# ===== AI Media Agent 配置 =====
# 请填入你的 API Key

# (必填) LLM 提供商 — 默认通义千问 Qwen compatible-mode
LLM_PROVIDER=alibaba

# (可选覆盖) LLM 模型 ID；留空则用该供应商配置的 default_model
LLM_MODEL=qwen-max

# (可选) 图片视觉理解专用模型；留空则按 LLM_PROVIDER 自动选择（alibaba → qwen-vl-max）
# 切勿填 qwen-max 等纯文本模型，否则会出现「无法查看图片」
# LLM_VISION_MODEL=qwen-vl-max
# (可选) 视觉分析专用供应商；截图分析推荐 alibaba / qwen / dashscope
# LLM_VISION_PROVIDER=alibaba

# (推荐) 通义 DashScope API Key — https://dashscope.console.aliyun.com
ALIBABA_API_KEY=
# 与 ALIBABA_API_KEY 任选其一填写即可
DASHSCOPE_API_KEY=

# (推荐) 图片拆层 · 百炼 DashScope 高精度流水线
# Qwen-VL 语义布局 + 逐元素抠图 + 掩膜背景修复
# 只需 DASHSCOPE_API_KEY / ALIBABA_API_KEY
# QWEN_LAYERED_DASHSCOPE_MODEL=wan2.7-image-pro
# PSD_ELEMENT_EDIT_MODEL=qwen-image-2.0-pro
# PSD_LAYOUT_VISION_MAX_EDGE=1920
# PSD_MAX_REFINE_PASSES=8

# (可选) 智谱 API Key — https://open.bigmodel.cn
ZHIPUAI_API_KEY=

# (可选) Google API Key — https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# (可选) DeepSeek API Key
DEEPSEEK_API_KEY=

# (可选) OpenRouter API Key — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# (可选) /last30days 多源调研 Skill — https://github.com/mvanhorn/last30days-skill
# Reddit/HN/Polymarket/GitHub 零配置可用；推理层默认复用上方 DASHSCOPE_API_KEY（通义 Qwen）
# LAST30DAYS_MEMORY_DIR=storage/research/last30days
# LAST30DAYS_REASONING_PROVIDER=dashscope
# LAST30DAYS_PLANNER_MODEL=qwen-plus
# LAST30DAYS_RERANK_MODEL=qwen-plus
# SCRAPECREATORS_API_KEY=
# BRAVE_API_KEY=
# BSKY_HANDLE=
# BSKY_APP_PASSWORD=

# (可选) 即梦/火山引擎 — https://console.volcengine.com
JIMENG_ACCESS_KEY=
JIMENG_SECRET_KEY=
BYTEDANCE_API_KEY=

# (可选) OpenAI API Key
OPENAI_API_KEY=

# (可选) 一键短视频 — 免版权视频素材
# Pexels: https://www.pexels.com/api/  ·  Pixabay: https://pixabay.com/api/docs/
PEXELS_API_KEY=
PIXABAY_API_KEY=

# (可选) 桌宠 Sidecar 本地 Ollama — http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1/
OLLAMA_MODEL=llama3.2:3b
OLLAMA_API_KEY=ollama

# (可选) 餐费模块对外 Web 根地址（群消息「表单」链接；默认 localhost:3000）
# 使用 Cloudflare Tunnel 时填公网前端域名，例如 https://tech-huhao.tech
MEAL_WEB_BASE_URL=https://tech-huhao.tech
# (可选) 桌面包自动启动 Cloudflare Tunnel（1=启用，需 cloudflared + ~/.cloudflared/config.yml）
CLOUDFLARE_TUNNEL_ENABLED=1
CLOUDFLARE_TUNNEL_NAME=gosteam-tech

# (可选) Jenkins 运维 — 飞书/Web 白名单触发构建
JENKINS_URL=https://jenkins.example.com
JENKINS_USER=your_user
JENKINS_API_TOKEN=

# ===== 安全 / 认证 =====
# 生产环境务必设置强随机 JWT 密钥；启用 AUTH_REQUIRED 后写操作需 Bearer Token
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 设为 true 时，知识库写操作、发布、Computer Use 等需登录
AUTH_REQUIRED=false
# CORS 白名单（逗号分隔）；留空则允许 localhost:3000/8000
# CORS_ALLOW_ORIGINS=http://localhost:3000,https://your-domain.com
# CORS_ALLOW_ORIGINS=*

# (可选) TAPD 缺陷 — 飞书工作台「TAPD 提 Bug」
# 项目 ID 见 TAPD 项目设置；API 账号在公司管理 > 开放集成 > API 账号管理
TAPD_WORKSPACE_ID=
TAPD_API_USER=
TAPD_API_PASSWORD=
# 或使用 OAuth Access Token（二选一）
# TAPD_ACCESS_TOKEN=
# TAPD_WEB_BASE=https://www.tapd.cn
# TAPD_API_BASE=https://api.tapd.cn
