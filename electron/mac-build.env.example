# macOS 公证凭据 — 复制为 mac-build.env 并填入真实值
# cp mac-build.env.example mac-build.env
#
# mac-build.env 已被 .gitignore 忽略，请勿提交到 Git

# 你的 Apple ID 邮箱（登录 appleid.apple.com 用的那个）
APPLE_ID=your@email.com

# App 专用密码（在 appleid.apple.com → 登录与安全 → App 专用密码 生成）
# 格式类似 xxxx-xxxx-xxxx-xxxx，可以带或不带连字符
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Team ID（在 developer.apple.com → Membership → Team ID 中查找）
APPLE_TEAM_ID=XXXXXXXXXX
