# ChromaDB 配置示例
# 复制此文件为 .env 并根据需要修改

# ===================
# 模式选择
# ===================

# 是否使用 HTTP 客户端连接 ChromaDB 服务器
# false = 使用本地嵌入式存储（默认，无需 Docker）
# true = 使用 HTTP 连接 ChromaDB 服务器（需要启动 Docker）
CHROMA_USE_HTTP=false

# ===================
# HTTP 模式配置（当 CHROMA_USE_HTTP=true 时使用）
# ===================

# ChromaDB 服务器地址
CHROMA_HOST=localhost

# ChromaDB 服务器端口
CHROMA_PORT=8001

# Collection 名称
CHROMA_COLLECTION_NAME=knowledge_base

# ===================
# 可选：认证配置（如果需要）
# ===================

# CHROMA_SERVER_AUTHN_PROVIDER=chromadb.auth.token_authn.TokenAuthenticationServerProvider
# CHROMA_SERVER_AUTHN_CREDENTIALS=your-secret-token
